# Copy to .env.local and fill in. Required-by-phase noted alongside each var.

# ── Required from 1.1 (Auth) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
CUSTOMER_JWT_SECRET=

# ── Required from 1.2 (Database — Supabase Free) ─────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Required from 1.5 (Cloudflare Pages deploy) ──────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ── Required from 1.6 (Shopify) ──────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=sblossom.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── Required from 1.7 (Cloudflare R2) ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_MOCKUPS_BUCKET=sblossom-mockups
R2_QC_PHOTOS_BUCKET=sblossom-qc-photos
R2_PUBLIC_BASE_URL=

# ── Required from 1.8 (Interakt) — unless MOCK_INTERAKT=1 ────────────────────
INTERAKT_API_KEY=
INTERAKT_WEBHOOK_VERIFY_TOKEN=
MOCK_INTERAKT=1

# ── Phase 2.9 (Shipmozo) ─────────────────────────────────────────────────────
SHIPMOZO_API_KEY=
SHIPMOZO_API_SECRET=
SHIPMOZO_BASE_URL=
MOCK_SHIPMOZO=1

# ── Phase 4.3 (Team alerts) ──────────────────────────────────────────────────
TEAM_ALERT_WEBHOOK=
